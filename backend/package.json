  "scripts": {
    "dev": "nodemon",
    "build": "npm run tsoa:routes && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && esbuild dist/**/*.js --minify --outdir=dist --allow-overwrite",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "openapi": "tsoa spec && shx cp build/openapi.json ../frontend/src/api/openapi.json",
    "tsoa:spec": "tsoa spec && shx cp build/openapi.json ../frontend/src/api/openapi.json",
    "tsoa:routes": "tsoa routes",
    "tsoa:generate": "tsoa spec-and-routes && shx cp build/openapi.json ../frontend/src/api/openapi.json"
  },
